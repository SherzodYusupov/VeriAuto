# Copy this file to .env and fill in your real values
# Never commit .env to git

# Server
PORT=4000
BASE_URL=http://localhost:3000

# Stripe — get from stripe.com/dashboard
STRIPE_PAYMENT_LINK=https://buy.stripe.com/your_link_here
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Email — use Gmail App Password
# Instructions: myaccount.google.com → Security → 2FA → App Passwords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=verify@veriaut.com.au
SMTP_PASS=your_gmail_app_password_here
EMAIL_FROM="VeriAuto <verify@veriaut.com.au>"

# Operator
OPERATOR_EMAIL=your@email.com

# Cloudflare R2 — create bucket at dash.cloudflare.com → R2
# API tokens: dash.cloudflare.com/profile/api-tokens → R2 Token
R2_ACCOUNT_ID=your_cloudflare_account_id
R2_ACCESS_KEY_ID=your_r2_access_key_id
R2_SECRET_ACCESS_KEY=your_r2_secret_access_key
R2_BUCKET_NAME=veriaut-uploads

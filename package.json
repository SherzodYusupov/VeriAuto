{
  "name": "veriaut-phase1",
  "version": "1.0.0",
  "description": "VeriAuto Phase 1 — Verified Car Listing Platform",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:frontend\" \"npm run dev:backend\"",
    "dev:frontend": "vite",
    "dev:backend": "node --watch server.js",
    "build": "vite build",
    "preview": "vite preview",
    "setup:python": "pip install -r scripts/requirements.txt --break-system-packages"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1049.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.3",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^6.9.13",
    "qrcode": "^1.5.3",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.15.1",
    "sql.js": "^1.14.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.5",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.1",
    "concurrently": "^8.2.2",
    "vite": "^5.4.2"
  }
}
